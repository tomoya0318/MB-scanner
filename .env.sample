############################################################
# .env.sample - MB-Scanner 設定例
############################################################

# mb-analyzer CLI バンドル (dist/cli.js) のパス（任意。未指定なら cwd 基準のデフォルト位置）
# MB_SCANNER_MB_ANALYZER_CLI_PATH="/path/to/mb-analyzer/dist/cli.js"

# mb-analyzer を起動する Node.js 実行ファイル（任意。PATH 上なら "node" のまま）
# MB_SCANNER_MB_ANALYZER_NODE_BIN="node"
